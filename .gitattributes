* text=auto
.gitattributes text eol=lf

# Always LF for files that run on Linux servers
*.py text eol=lf
*.sh text eol=lf
installer/files/opanelctl text eol=lf
*.j2 text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf

# Frontend / web files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
