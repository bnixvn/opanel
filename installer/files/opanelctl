#!/usr/bin/env bash
# BPanel SSH rescue menu.

set -euo pipefail

APP_DIR="${APP_DIR:-/opt/bpanel}"
ENV_FILE="${APP_DIR}/backend/.env"
BACKUP_ROOT="${BACKUP_ROOT:-/var/backups/bpanel}"
DEFAULT_PANEL_PORT="2222"

if [[ $EUID -ne 0 ]]; then
  echo "Please run as root"
  exit 1
fi

fail() { echo "ERROR: $*" >&2; exit 1; }

ensure_env_file() {
  [[ -f "$ENV_FILE" ]] || fail "$ENV_FILE not found. Run installer first."
}

env_get() {
  local key="$1"
  [[ -f "$ENV_FILE" ]] || return 0
  awk -F= -v key="$key" '$1 == key { sub(/^[^=]*=/, ""); print; exit }' "$ENV_FILE"
}

env_set() {
  local key="$1" value="$2"
  ensure_env_file
  local escaped
  escaped="$(printf '%s' "$value" | sed -e 's/[&|]/\\&/g')"
  if grep -q "^${key}=" "$ENV_FILE"; then
    sed -i "s|^${key}=.*|${key}=${escaped}|" "$ENV_FILE"
  else
    printf '%s=%s\n' "$key" "$value" >>"$ENV_FILE"
  fi
}

detect_ip() {
  hostname -I 2>/dev/null | awk '{print $1}' || true
}

find_sshd() {
  if command -v sshd >/dev/null 2>&1; then
    command -v sshd
    return 0
  fi
  for candidate in /usr/sbin/sshd /usr/local/sbin/sshd; do
    [[ -x "$candidate" ]] && { echo "$candidate"; return 0; }
  done
  return 1
}

detect_ssh_ports() {
  local sshd_bin
  sshd_bin="$(find_sshd || true)"
  {
    if [[ -n "$sshd_bin" ]]; then
      "$sshd_bin" -T 2>/dev/null | awk '$1 == "port" {print $2}'
    fi
    if [[ -n "${SSH_CONNECTION:-}" ]]; then
      awk '{print $4}' <<<"$SSH_CONNECTION"
    fi
    awk '
      tolower($1) == "port" && $2 ~ /^[0-9]+$/ { print $2 }
      tolower($1) == "listenaddress" {
        for (i = 2; i <= NF; i++) {
          value = $i
          gsub(/^\[/, "", value)
          gsub(/\]$/, "", value)
          if (value ~ /:[0-9]+$/) {
            sub(/^.*:/, "", value)
            print value
          }
        }
      }
    ' /etc/ssh/sshd_config /etc/ssh/sshd_config.d/*.conf 2>/dev/null
  } | awk '$1 ~ /^[0-9]+$/ && $1 >= 1 && $1 <= 65535 {print $1}' | sort -nu
}

normalize_domain() {
  local value="$1"
  value="${value#http://}"
  value="${value#https://}"
  value="${value%%/*}"
  value="${value%%:*}"
  printf '%s' "$value"
}

validate_domain() {
  [[ "$1" =~ ^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?(\.[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?)+$ ]] \
    || fail "Invalid domain: $1"
}

validate_port() {
  [[ "$1" =~ ^[0-9]{1,5}$ ]] || fail "Invalid port: $1"
  (( "$1" >= 1 && "$1" <= 65535 )) || fail "Port out of range: $1"
}

restart_panel() {
  systemctl daemon-reload || true
  systemctl restart bpanel-api
}

login_password_from_file() {
  [[ -f /root/login.txt ]] || return 0
  sed -n 's/^Password: //p' /root/login.txt | head -n 1
}

write_login_info() {
  ensure_env_file
  local password="${1:-}" url tmp
  url="$(env_get PANEL_URL)"
  if [[ -z "$password" ]]; then
    password="$(login_password_from_file)"
  fi
  password="${password:-<not available; run bpanel change-admin-password>}"
  (
    if command -v flock >/dev/null 2>&1; then
      flock -x 9
    fi
    tmp="$(mktemp /root/login.txt.XXXXXX)"
    chmod 600 "$tmp"
    cat >"$tmp" <<INFO
Panel URL: ${url}
User: admin
Password: ${password}
INFO
    mv -f "$tmp" /root/login.txt
  ) 9>/root/.bpanel-login.lock
  chmod 600 /root/login.txt
}

delete_bpanel_ufw_rules() {
  local pattern="$1" number
  command -v ufw >/dev/null 2>&1 || return 0
  while read -r number; do
    [[ -n "$number" ]] || continue
    ufw --force delete "$number" >/dev/null 2>&1 || true
  done < <(
    ufw status numbered 2>/dev/null \
      | awk -v pattern="$pattern" '
          index($0, "bpanel:PanelZone") {
            line = $0
            if (!match(line, /^\[[[:space:]]*[0-9]+\]/)) {
              next
            }
            number = substr(line, RSTART, RLENGTH)
            gsub(/[^0-9]/, "", number)
            sub(/^\[[[:space:]]*[0-9]+\][[:space:]]*/, "", line)
            split(line, parts, /[[:space:]]+ALLOW[[:space:]]+/)
            target = parts[1]
            if (target == pattern || target == pattern " (v6)") {
              print number
            }
          }
        ' \
      | sort -rn
  )
}

allow_panel_port() {
  local port="$1"
  if command -v ufw >/dev/null 2>&1; then
    delete_bpanel_ufw_rules "${port}/tcp"
    ufw insert 1 allow "${port}/tcp" comment "bpanel:PanelZone" >/dev/null 2>&1 \
      || ufw insert 1 allow "${port}/tcp" >/dev/null 2>&1 \
      || ufw allow "${port}/tcp" >/dev/null 2>&1 \
      || true
  fi
}

allow_panel_app() {
  local app="$1"
  if command -v ufw >/dev/null 2>&1; then
    delete_bpanel_ufw_rules "$app"
    ufw insert 1 allow "$app" comment "bpanel:PanelZone" >/dev/null 2>&1 \
      || ufw insert 1 allow "$app" >/dev/null 2>&1 \
      || ufw allow "$app" >/dev/null 2>&1 \
      || true
  fi
}

close_old_panel_port() {
  local old_port="$1" new_port="$2"
  [[ -n "$old_port" && "$old_port" != "$new_port" ]] || return 0
  case "$old_port" in
    22|80|443|465|587) return 0 ;;
  esac
  if command -v ufw >/dev/null 2>&1; then
    delete_bpanel_ufw_rules "${old_port}/tcp"
  fi
}

refresh_phpmyadmin_api_base() {
  local signon="/usr/share/phpmyadmin/bpanel-signon.php"
  [[ -f "$signon" ]] || return 0
  local scheme="$1" port="$2"
  sed -i -E "/api\/databases\/phpmyadmin-sso/s#'[^']+/api/databases/phpmyadmin-sso/'#'${scheme}://127.0.0.1:${port}/api/databases/phpmyadmin-sso/'#" "$signon" || true
}

refresh_tools_nginx() {
  local port cert key domain host api_scheme tools_scheme pma_secure ssl_block php_version
  port="$(env_get PANEL_PORT)"; port="${port:-$DEFAULT_PANEL_PORT}"
  cert="$(env_get PANEL_SSL_CERT)"; key="$(env_get PANEL_SSL_KEY)"
  domain="$(env_get PANEL_DOMAIN)"; host="${domain:-$(detect_ip)}"
  php_version="${PHP_DEFAULT:-8.3}"
  api_scheme="http"; tools_scheme="http"; pma_secure="false"; ssl_block=""
  if [[ -n "$cert" && -n "$key" && -f "$cert" && -f "$key" ]]; then
    api_scheme="https"; tools_scheme="https"; pma_secure="true"
    printf -v ssl_block '\n    listen 443 ssl default_server;\n    ssl_certificate %s;\n    ssl_certificate_key %s;' "$cert" "$key"
  fi
  rm -f /etc/nginx/sites-enabled/default /etc/nginx/conf.d/default.conf 2>/dev/null || true
  cat >/etc/nginx/conf.d/00-bpanel-tools.conf <<NGINX
server {
    listen 80 default_server;${ssl_block}
    server_name _;
    client_max_body_size 1100M;
    location = /phpmyadmin { return 301 /phpmyadmin/; }
    location /phpmyadmin/ { alias /usr/share/phpmyadmin/; index index.php; try_files \$uri \$uri/ =404; }
    location ~ ^/phpmyadmin/(.+\.php)$ { alias /usr/share/phpmyadmin/\$1; include fastcgi_params; fastcgi_param SCRIPT_FILENAME /usr/share/phpmyadmin/\$1; fastcgi_param SCRIPT_NAME /phpmyadmin/\$1; fastcgi_pass unix:/run/php/php${php_version}-fpm.sock; fastcgi_read_timeout 300; }
}
NGINX
  refresh_phpmyadmin_api_base "$api_scheme" "$port"
  sed -i -E "s#('secure' => )(true|false)#\1${pma_secure}#" /etc/phpmyadmin/conf.d/bpanel-signon.php /usr/share/phpmyadmin/bpanel-signon.php 2>/dev/null || true
  [[ -n "$host" ]] && sed -i -E "/PmaAbsoluteUri/s#'https?://[^']+/phpmyadmin/'#'${tools_scheme}://${host}/phpmyadmin/'#" /etc/phpmyadmin/conf.d/bpanel-signon.php 2>/dev/null || true
  nginx -t && systemctl reload nginx || true
}

set_panel_url() {
  ensure_env_file
  local current_port current_domain domain host port scheme url cert key
  current_port="$(env_get PANEL_PORT)"
  current_port="${current_port:-$DEFAULT_PANEL_PORT}"
  current_domain="$(env_get PANEL_DOMAIN)"
  read -rp "Panel domain (blank for server IP): " domain
  read -rp "Panel port [${current_port}]: " port
  port="${port:-$current_port}"
  validate_port "$port"

  if [[ -n "$domain" ]]; then
    domain="$(normalize_domain "$domain")"
    validate_domain "$domain"
    host="$domain"
    env_set PANEL_DOMAIN "$domain"
  else
    host="$(detect_ip)"
    [[ -n "$host" ]] || fail "Cannot detect server IP. Enter a panel domain instead."
    env_set PANEL_DOMAIN ""
  fi

  cert="$(env_get PANEL_SSL_CERT)"
  key="$(env_get PANEL_SSL_KEY)"
  scheme="http"
  if [[ -n "$domain" && "$current_domain" == "$domain" && -n "$cert" && -n "$key" && -f "$cert" && -f "$key" ]]; then
    scheme="https"
  fi
  url="${scheme}://${host}:${port}"

  env_set PANEL_PORT "$port"
  env_set PANEL_URL "$url"
  env_set ALLOWED_ORIGINS "$url"
  if [[ "$scheme" == "http" ]]; then
    env_set PANEL_SSL_CERT ""
    env_set PANEL_SSL_KEY ""
  fi
  allow_panel_port "$port"
  close_old_panel_port "$current_port" "$port"
  write_login_info
  refresh_phpmyadmin_api_base "$scheme" "$port"
  refresh_tools_nginx
  restart_panel
  echo "Panel URL: $url"
}

install_panel_ssl() {
  ensure_env_file
  local domain email port url
  domain="$(env_get PANEL_DOMAIN)"
  if [[ -z "$domain" ]]; then
    read -rp "Panel domain: " domain
    domain="$(normalize_domain "$domain")"
  fi
  validate_domain "$domain"
  email="$(env_get SSL_EMAIL)"
  if [[ -z "$email" ]]; then
    read -rp "Let's Encrypt email: " email
  fi
  [[ "$email" =~ ^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$ ]] || fail "Invalid email"

  echo "Issuing certificate for $domain. Nginx may be stopped briefly for port 80 validation."
  certbot certonly --standalone \
    -d "$domain" \
    --email "$email" \
    --agree-tos \
    --non-interactive \
    --pre-hook "systemctl stop nginx || true" \
    --post-hook "systemctl start nginx || true" \
    --deploy-hook "install -d -o root -g bpanel -m 0750 /etc/bpanel && install -m 0640 -o root -g bpanel /etc/letsencrypt/live/${domain}/fullchain.pem /etc/bpanel/panel-fullchain.pem && install -m 0640 -o root -g bpanel /etc/letsencrypt/live/${domain}/privkey.pem /etc/bpanel/panel-privkey.pem && systemctl restart bpanel-api || true"

  install -d -o root -g bpanel -m 0750 /etc/bpanel
  install -m 0640 -o root -g bpanel "/etc/letsencrypt/live/${domain}/fullchain.pem" /etc/bpanel/panel-fullchain.pem
  install -m 0640 -o root -g bpanel "/etc/letsencrypt/live/${domain}/privkey.pem" /etc/bpanel/panel-privkey.pem

  port="$(env_get PANEL_PORT)"
  port="${port:-$DEFAULT_PANEL_PORT}"
  url="https://${domain}:${port}"
  env_set PANEL_DOMAIN "$domain"
  env_set PANEL_SSL_CERT "/etc/bpanel/panel-fullchain.pem"
  env_set PANEL_SSL_KEY "/etc/bpanel/panel-privkey.pem"
  env_set PANEL_URL "$url"
  env_set ALLOWED_ORIGINS "$url"
  env_set SSL_EMAIL "$email"
  allow_panel_port "$port"
  write_login_info
  refresh_phpmyadmin_api_base "https" "$port"
  refresh_tools_nginx
  restart_panel
  echo "Panel SSL enabled: $url"
}

fix_permissions() {
  ensure_env_file
  getent group bpanel-sites >/dev/null || groupadd --system bpanel-sites
  getent group bpanel-sftp >/dev/null || groupadd --system bpanel-sftp
  if ! command -v setfacl >/dev/null 2>&1 && command -v apt-get >/dev/null 2>&1; then
    DEBIAN_FRONTEND=noninteractive apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y acl
  fi
  usermod -aG bpanel-sites bpanel 2>/dev/null || true
  usermod -aG bpanel-sites www-data 2>/dev/null || true
  if command -v sshd >/dev/null 2>&1; then
    local sshd_config="/etc/ssh/sshd_config"
    local sshd_backup="${sshd_config}.bpanel.bak"
    install -d -o root -g root -m 0755 /run/sshd
    rm -f /etc/ssh/sshd_config.d/99-bpanel-sftp.conf 2>/dev/null || true
    touch "$sshd_config"
    cp "$sshd_config" "$sshd_backup"
    sed -i '/^# BEGIN BPANEL SFTP USERS$/,/^# END BPANEL SFTP USERS$/d' "$sshd_config"
    cat >>"$sshd_config" <<'SSHD'
# BEGIN BPANEL SFTP USERS
# Allow BPanel Linux users to log in with SFTP using their panel password.
Match Group bpanel-sftp
    PasswordAuthentication yes
    X11Forwarding no
    AllowTcpForwarding no
# END BPANEL SFTP USERS
SSHD
    if sshd -t; then
      systemctl reload ssh 2>/dev/null || systemctl reload sshd 2>/dev/null || true
    else
      cp "$sshd_backup" "$sshd_config"
      echo "WARNING: invalid SSHD configuration; skipped BPanel SFTP password block"
    fi
  fi
  install -d -o bpanel -g bpanel -m 0750 "$APP_DIR" "$APP_DIR/backend" "$APP_DIR/frontend"
  install -d -o root -g bpanel -m 2775 /etc/nginx/conf.d
  chmod g+s /etc/nginx/conf.d 2>/dev/null || true
  install -d -o bpanel -g bpanel -m 0750 "$BACKUP_ROOT"
  install -d -o bpanel -g bpanel -m 0750 /var/lib/bpanel
  if [[ -d /etc/bpanel ]]; then
    chown root:bpanel /etc/bpanel /etc/bpanel/* 2>/dev/null || true
    chmod 0750 /etc/bpanel 2>/dev/null || true
    chmod 0640 /etc/bpanel/* 2>/dev/null || true
  fi
  chown -R bpanel:bpanel "$APP_DIR/backend" "$APP_DIR/frontend" 2>/dev/null || true
  chown bpanel:bpanel /var/lib/bpanel 2>/dev/null || true
  [[ -d /var/lib/bpanel/assets ]] && chown -R bpanel:bpanel /var/lib/bpanel/assets 2>/dev/null || true
  chmod 0640 "$ENV_FILE" 2>/dev/null || true
  if [[ -d "$APP_DIR/frontend/dist" ]]; then
    chmod o+rX "$APP_DIR" "$APP_DIR/frontend" 2>/dev/null || true
    chmod -R o+rX "$APP_DIR/frontend/dist"
  fi
  if [[ -x "$APP_DIR/backend/.venv/bin/python" ]]; then
    cd "$APP_DIR/backend"
    runuser -u bpanel -- env HOME="$APP_DIR" BPANEL_USE_HELPER=true "$APP_DIR/backend/.venv/bin/python" - <<'PY'
from app.core.database import SessionLocal
from app.models.entities import Website
from app.services import nginx, site_users, waf

db = SessionLocal()
try:
    websites = db.query(Website).all()
    result = nginx.sync_http_flood_zones(websites)
    if result.returncode != 0:
        raise RuntimeError(result.stderr or result.stdout or "Unable to sync HTTP flood zones")
    for website in websites:
        if website.linux_user:
            runtime_php_version = website.php_version if (website.app_type or "wordpress") in {"wordpress", "php"} else None
            site_users.ensure_site_runtime(website.domain, website.root_path, runtime_php_version, website.linux_user)
            site_users.ensure_document_root(
                website.root_path,
                getattr(website, "document_root", "public_html") or "public_html",
                website.linux_user,
            )
        site_users.fix_site_permissions(website.root_path, website.linux_user)
        app_type = website.app_type or "wordpress"
        runtime_php_version = website.php_version if app_type in {"wordpress", "php"} else None
        result = waf.sync_website_rules(website)
        if result.returncode != 0:
            raise RuntimeError(result.stderr or result.stdout or "Unable to sync WAF rules")
        if getattr(website, "nginx_config_mode", "managed") != "managed":
            website.nginx_config_mode = "managed"
            db.commit()
        nginx.rewrite_vhost(
            website.domain,
            website.root_path,
            app_type=app_type,
            php_version=website.php_version,
            custom_directives=website.nginx_custom or "",
            php_fpm_socket_override=site_users.site_php_fpm_socket(website.linux_user, website.root_path, runtime_php_version),
            waf_enabled=website.waf_enabled,
            http_flood_enabled=website.http_flood_enabled,
            http_flood_config=website.http_flood_config or "",
            document_root=getattr(website, "document_root", "public_html") or "public_html",
        )
    result = nginx.sync_http_flood_zones(websites)
    if result.returncode != 0:
        raise RuntimeError(result.stderr or result.stdout or "Unable to sync HTTP flood zones")
finally:
    db.close()
PY
  fi
  restart_panel
  refresh_tools_nginx
  echo "Permissions fixed."
}

change_admin_password() {
  ensure_env_file
  local password confirm runner
  read -rsp "New admin password: " password; echo
  read -rsp "Confirm password: " confirm; echo
  [[ "$password" == "$confirm" ]] || fail "Passwords do not match"
  [[ ${#password} -ge 12 ]] || fail "Password must be at least 12 characters"

  cd "$APP_DIR/backend"
  if id -u bpanel >/dev/null 2>&1; then
    runner=(runuser -u bpanel -- env HOME="$APP_DIR" BPANEL_USE_HELPER=true "BPANEL_NEW_ADMIN_PASSWORD=$password" "$APP_DIR/backend/.venv/bin/python")
  else
    runner=(env HOME="$APP_DIR" BPANEL_USE_HELPER=true "BPANEL_NEW_ADMIN_PASSWORD=$password" "$APP_DIR/backend/.venv/bin/python")
  fi
  "${runner[@]}" - <<'PY'
import os
from app.core.database import SessionLocal
from app.core.security import hash_password
from app.models.entities import User
from app.services import site_users

password = os.environ["BPANEL_NEW_ADMIN_PASSWORD"]
db = SessionLocal()
try:
    user = db.query(User).filter(User.username == "admin").first()
    if not user:
        raise SystemExit("admin user not found")
    site_users.set_panel_user_password(user.username, password)
    user.hashed_password = hash_password(password)
    user.token_version = (user.token_version or 0) + 1
    db.commit()
finally:
    db.close()
PY
  write_login_info "$password"
  echo "Admin password changed. Existing sessions were invalidated."
}

root_password_hash() {
  local hash
  hash="$(getent shadow root 2>/dev/null | awk -F: '{print $2; exit}')"
  if [[ -z "$hash" && -r /etc/shadow ]]; then
    hash="$(awk -F: '$1 == "root" {print $2; exit}' /etc/shadow)"
  fi
  printf '%s' "$hash"
}

validate_root_password_hash() {
  local hash="$1"
  [[ -n "$hash" ]] || fail "Cannot read root password hash from /etc/shadow"
  case "$hash" in
    \!*|\**|x) fail "Root account does not have an unlocked password hash" ;;
  esac
  case "$hash" in
    \$y\$*|\$gy\$*|\$7\$*|\$6\$*|\$5\$*|\$2a\$*|\$2b\$*|\$2y\$*) ;;
    *) fail "Unsupported root password hash format: ${hash%%\$*}" ;;
  esac
}

sync_admin_root_password() {
  ensure_env_file
  local root_hash runner login_password
  root_hash="$(root_password_hash)"
  validate_root_password_hash "$root_hash"

  if [[ -x /usr/local/sbin/bpanel-helper ]]; then
    if [[ "$(id -un)" == "bpanel" ]]; then
      sudo -n /usr/local/sbin/bpanel-helper panel-user-ensure admin
    elif id -u bpanel >/dev/null 2>&1; then
      runuser -u bpanel -- sudo -n /usr/local/sbin/bpanel-helper panel-user-ensure admin
    else
      /usr/local/sbin/bpanel-helper panel-user-ensure admin
    fi
  fi
  id -u admin >/dev/null 2>&1 || fail "Linux user admin not found"
  usermod -p "$root_hash" admin
  passwd -u admin >/dev/null 2>&1 || true

  cd "$APP_DIR/backend"
  if id -u bpanel >/dev/null 2>&1; then
    runner=(runuser -u bpanel -- env HOME="$APP_DIR" BPANEL_USE_HELPER=true "BPANEL_ROOT_PASSWORD_HASH=$root_hash" "$APP_DIR/backend/.venv/bin/python")
  else
    runner=(env HOME="$APP_DIR" BPANEL_USE_HELPER=true "BPANEL_ROOT_PASSWORD_HASH=$root_hash" "$APP_DIR/backend/.venv/bin/python")
  fi
  "${runner[@]}" - <<'PY'
import os
from app.core.database import SessionLocal
from app.models.entities import User

root_hash = os.environ["BPANEL_ROOT_PASSWORD_HASH"]
db = SessionLocal()
try:
    user = db.query(User).filter(User.username == "admin").first()
    if not user:
        raise SystemExit("admin user not found")
    user.hashed_password = root_hash
    user.token_version = (user.token_version or 0) + 1
    db.commit()
finally:
    db.close()
PY
  read -rsp "Root password to write to /root/login.txt (blank to skip): " login_password; echo
  if [[ -n "$login_password" ]]; then
    write_login_info "$login_password"
  fi
  restart_panel
  echo "Admin password now matches the root password. Existing sessions were invalidated."
}

show_status() {
  ensure_env_file
  local port cert key scheme health_url health http_code curl_rc curl_error curl_stderr
  port="$(env_get PANEL_PORT)"; port="${port:-$DEFAULT_PANEL_PORT}"
  cert="$(env_get PANEL_SSL_CERT)"; key="$(env_get PANEL_SSL_KEY)"
  scheme="http"
  if [[ -n "$cert" && -n "$key" && -f "$cert" && -f "$key" ]]; then
    scheme="https"
  fi
  health_url="${scheme}://127.0.0.1:${port}/api/health"
  if ! command -v curl >/dev/null 2>&1; then
    health="unknown (curl not found)"
  else
    curl_stderr="$(mktemp)"
    curl_rc=0
    http_code="$(curl -ksS --connect-timeout 2 --max-time 5 -o /dev/null -w '%{http_code}' "$health_url" 2>"$curl_stderr")" || curl_rc=$?
    curl_error="$(tr '\n' ' ' <"$curl_stderr" | sed -e 's/[[:space:]]*$//')"
    rm -f "$curl_stderr"
    if [[ "$curl_rc" -eq 0 && "$http_code" == "200" ]]; then
      health="ok (HTTP 200)"
    else
      health="failed (curl=${curl_rc}, http=${http_code:-000}${curl_error:+, ${curl_error}})"
    fi
  fi
  echo "Panel URL: $(env_get PANEL_URL)"
  echo "Local health: ${health} (${health_url})"
  echo "API: $(systemctl is-active bpanel-api 2>/dev/null || echo unknown)"
  echo "Nginx: $(systemctl is-active nginx 2>/dev/null || echo unknown)"
  echo "MariaDB: $(systemctl is-active mariadb 2>/dev/null || echo unknown)"
  echo "Redis: $(systemctl is-active redis-server 2>/dev/null || echo unknown)"
  if command -v ufw >/dev/null 2>&1; then
    echo "UFW: $(ufw status 2>/dev/null | head -n 1)"
  fi
}

show_login_info() {
  ensure_env_file
  if [[ -f /root/login.txt ]]; then
    cat /root/login.txt
    return 0
  fi
  echo "Panel URL: $(env_get PANEL_URL)"
  echo "User: admin"
  echo "Password: <not available; run bpanel change-admin-password>"
  echo "Note: /root/login.txt is missing and database password hashes cannot be reversed."
}

restart_panel_command() {
  systemctl daemon-reload || true
  for service in mariadb redis-server nginx bpanel-api; do
    if systemctl restart "$service" 2>/dev/null; then
      echo "${service}: restarted"
    else
      echo "${service}: failed"
    fi
  done
}

show_logs() {
  echo "== bpanel-api =="
  journalctl -u bpanel-api -n 120 --no-pager 2>/dev/null || true
  echo ""
  echo "== nginx error.log =="
  tail -n 80 /var/log/nginx/error.log 2>/dev/null || echo "No nginx error log found."
  if [[ -f /var/log/bpanel-panel-update.log ]]; then
    echo ""
    echo "== bpanel update =="
    tail -n 80 /var/log/bpanel-panel-update.log
  fi
}

repair_firewall() {
  ensure_env_file
  local panel_port ssh_port port seen_ssh_ports
  panel_port="$(env_get PANEL_PORT)"; panel_port="${panel_port:-$DEFAULT_PANEL_PORT}"
  validate_port "$panel_port"
  allow_panel_app OpenSSH
  seen_ssh_ports="$(detect_ssh_ports)"
  while read -r ssh_port; do
    [[ -n "$ssh_port" ]] || continue
    [[ "$ssh_port" == "22" ]] && continue
    allow_panel_port "$ssh_port"
  done <<<"$seen_ssh_ports"
  allow_panel_app 'Nginx Full'
  for port in 465 587 "$panel_port"; do
    case "$port" in
      80|443) continue ;;
    esac
    allow_panel_port "$port"
  done
  if command -v ufw >/dev/null 2>&1; then
    ufw status numbered || true
  fi
  echo "Firewall rescue rules refreshed."
}

run_panel_update() {
  [[ -x /usr/local/sbin/bpanel-update ]] || fail "/usr/local/sbin/bpanel-update not found"
  read -rp "Update BPanel to the latest vX.Y.Z release now? [y/N]: " confirm
  case "$confirm" in
    y|Y|yes|YES) ;;
    *) echo "Canceled."; return 0 ;;
  esac
  /usr/local/sbin/bpanel-update --release
}

change_panel_ip() {
  local script="/usr/local/sbin/bpanel-change-ip" old_ip new_ip current_ip
  [[ -x "$script" ]] || fail "$script not found. Reinstall/update BPanel or copy change_IP.sh to that path."

  current_ip="$(detect_ip)"
  read -rp "Old IP: " old_ip
  if [[ -n "$current_ip" ]]; then
    read -rp "New IP [${current_ip}]: " new_ip
    new_ip="${new_ip:-$current_ip}"
  else
    read -rp "New IP: " new_ip
  fi
  "$script" "$old_ip" "$new_ip"
}

menu() {
  while true; do
    echo ""
    echo "BPanel SSH Rescue Menu"
    echo "1) Show login info"
    echo "2) Show rescue status"
    echo "3) View recent logs"
    echo "4) Restart panel services"
    echo "5) Repair firewall ports"
    echo "6) Set/reset panel URL / port"
    echo "7) Install/repair panel SSL"
    echo "8) Fix permissions/runtime"
    echo "9) Change admin password"
    echo "10) Update panel from release"
    echo "11) Change server IP"
    echo "12) Sync admin password from root"
    echo "0) Exit"
    read -rp "Choose: " choice
    case "$choice" in
      1) show_login_info ;;
      2) show_status ;;
      3) show_logs ;;
      4) restart_panel_command ;;
      5) repair_firewall ;;
      6) set_panel_url ;;
      7) install_panel_ssl ;;
      8) fix_permissions ;;
      9) change_admin_password ;;
      10) run_panel_update ;;
      11) change_panel_ip ;;
      12) sync_admin_root_password ;;
      0) exit 0 ;;
      *) echo "Invalid choice" ;;
    esac
  done
}

case "${1:-menu}" in
  menu|--menu) menu ;;
  login|--login|show-login|--show-login) show_login_info ;;
  logs|--logs) show_logs ;;
  restart|--restart) restart_panel_command ;;
  repair-firewall|--repair-firewall) repair_firewall ;;
  update|--update) run_panel_update ;;
  change-ip|--change-ip) change_panel_ip ;;
  set-panel-url|--set-panel-url) set_panel_url ;;
  install-panel-ssl|--install-panel-ssl) install_panel_ssl ;;
  fix-permissions|--fix-permissions) fix_permissions ;;
  change-admin-password|--change-admin-password) change_admin_password ;;
  sync-admin-root-password|--sync-admin-root-password|admin-use-root-password|--admin-use-root-password) sync_admin_root_password ;;
  status|--status) show_status ;;
  *)
    echo "Usage: bpanel [menu|login|status|logs|restart|repair-firewall|change-ip|set-panel-url|install-panel-ssl|fix-permissions|change-admin-password|sync-admin-root-password|update]"
    exit 2
    ;;
esac
