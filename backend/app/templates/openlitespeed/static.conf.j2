# OPanel managed vhost: {{ domain }}
# App type: static
# Generated by OPanel — do not edit manually.

docRoot                   {{ root_path }}/{{ document_root }}

vhDomain                  {{ domain }}
{% for alias in aliases %}
vhAliases                 {{ alias }}
{% endfor %}

enableGzip                1
enableBr                  1

index  {
    useServer             0
    indexFiles            index.html, index.htm
}

errorlog {{ error_log }} {
    useServer             0
    logLevel              WARN
    rollingSize           10M
}

accesslog {{ access_log }} {
    useServer             0
    rollingSize           100M
    keepDays              30
    logReferer            1
    logUserAgent          1
}

{% if has_ssl %}
vhssl {
    keyFile               {{ ssl_key_path }}
    certFile              {{ ssl_cert_path }}
{% if ssl_ca_path %}
    caBundlePath          {{ ssl_ca_path }}
{% endif %}
    certChain             1
}
{% endif %}

{% if ssl_enabled %}
rewrite {
    enable                1
    rewriteRules          <<<END_RULES
RewriteCond %{REQUEST_URI} !^/\.well-known/acme-challenge/
RewriteCond %{SERVER_PORT} 80
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
END_RULES
}
{% endif %}

{% if waf_enabled %}
# OPANEL WAF BEGIN
module mod_security {
    modsecurity           1
    modsecurity_rules_file  {{ waf_rules_file }}
}
# OPANEL WAF END
{% endif %}

# Static site: no PHP processor needed

context / {
    type                  null
    location              {{ root_path }}/{{ document_root }}
    allowOverride         all

    addDefaultCharset     off

    rewrite {
        enable              1
        inherit             1
    }
    extraHeaders <<<END_HEADERS
{% if hsts_header %}{{ hsts_header }}
{% endif %}{{ security_headers }}
END_HEADERS
}

context /.well-known/acme-challenge/ {
    type                  static
    location              {{ acme_webroot }}/.well-known/acme-challenge/
    allowBrowse           1
    addDefaultCharset     off
}

{% for redirect in redirects %}
rewrite {
    enable                1
    rewriteRules          <<<END_RULES
RewriteCond %{HTTP_HOST} ^(www\.)?{{ redirect.source }}$ [NC]
RewriteRule ^(.*)$ {{ redirect.target }}$1 [R={{ redirect.code|default(301) }},L]
END_RULES
}
{% endfor %}

{% if http_flood_enabled %}
{{ rewrite_block }}
{% endif %}

{% if custom_directives %}
{{ custom_directives }}
{% endif %}
